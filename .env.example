# Project — path to the repo this agent works on
REPO_ROOT=/path/to/your-project
CLAUDE_BIN=claude
FLUTTER_BIN=flutter
PROJECT_NAME=your-project-name

# Port: path to original project for source analysis (required for @PM port)
ORIGINAL_PROJECT_PATH=

# Linear
LINEAR_API_KEY=lin_api_...

# Dev Agent Slack App (api.slack.com/apps)
DEV_SLACK_BOT_TOKEN=xoxb-...
DEV_SLACK_APP_TOKEN=xapp-...

# PM Agent Slack App (api.slack.com/apps)
PM_SLACK_BOT_TOKEN=xoxb-...
PM_SLACK_APP_TOKEN=xapp-...

# Web Dashboard
WEB_PORT=3000
